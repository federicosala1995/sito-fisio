# ─── Supabase ───────────────────────────────────────────────────────────────
# Trovi questi valori su: supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Anthropic (AI assistant + piano seduta) ────────────────────────────────
# Mai esposta al browser — solo server-side
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (email transazionali) ───────────────────────────────────────────
# Crea account su resend.com, crea un API key
RESEND_API_KEY=re_...
# Dominio verificato su Resend (usa un indirizzo del tuo dominio)
RESEND_FROM=Federico Fisioterapista <prenotazioni@fisioterapistafederico.it>

# ─── Base URL del sito ──────────────────────────────────────────────────────
# In locale: http://localhost:3000  |  In produzione: https://tuodominio.it
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Cron security ──────────────────────────────────────────────────────────
# Segreto per proteggere /api/cron/reminders da chiamate esterne
# Genera con: openssl rand -hex 32
CRON_SECRET=cambia-con-stringa-casuale-sicura

# ─── WhatsApp ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=393454431758
